# Git attributes for Lisper project

# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.cpp text
*.c text
*.h text
*.hpp text
*.cc text
*.cxx text

# Build files
*.cmake text
CMakeLists.txt text
Makefile text
*.make text
*.mk text

# Documentation
*.md text
*.txt text
*.rst text
LICENSE text
README text
CHANGELOG text
AUTHORS text
CONTRIBUTING text

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.py text
*.pl text

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Config files
*.json text
*.yaml text
*.yml text
*.toml text
*.ini text
*.cfg text
*.conf text
.gitignore text
.gitattributes text
.editorconfig text

# Binary files (no diff)
*.bin binary
*.ggml binary
*.gguf binary
*.pt binary
*.pth binary
*.pkl binary
*.model binary
*.weights binary

# Model files for Git LFS (if using LFS)
# Uncomment these lines if you want to use Git LFS for large model files
# *.bin filter=lfs diff=lfs merge=lfs -text
# *.ggml filter=lfs diff=lfs merge=lfs -text
# *.gguf filter=lfs diff=lfs merge=lfs -text

# Media files (binary)
*.wav binary
*.mp3 binary
*.mp4 binary
*.aiff binary
*.aif binary
*.flac binary
*.ogg binary
*.m4a binary
*.aac binary
*.wma binary
*.mkv binary
*.avi binary
*.webm binary
*.mov binary
*.flv binary
*.wmv binary
*.m4v binary

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.bmp binary
*.svg text
*.ico binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary

# Compiled binaries
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.o binary
*.obj binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# IDE files
*.suo binary
*.user binary
*.userosscache binary
*.sln.docstates binary

# Linguist overrides (for GitHub language detection)
third_party/* linguist-vendored
docs/* linguist-documentation
*.h linguist-language=C++
*.hpp linguist-language=C++

# Diff patterns
*.cpp diff=cpp
*.h diff=cpp
*.hpp diff=cpp
*.c diff=cpp
*.py diff=python
*.md diff=markdown